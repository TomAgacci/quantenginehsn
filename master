# -------------------
# Quantitative Heidegger–Spinoza–Nietzsche engine:
#   - takes a concept
#   - returns numeric scores per lens
#   - builds combined vectors for math / ZCMS use

from __future__ import annotations
from dataclasses import dataclass, asdict
from typing import Dict, Any
import math


@dataclass
class HSNWeights:
    heidegger: float = 1.0
    spinoza: float = 1.0
    nietzsche: float = 1.0

    def normalized(self) -> "HSNWeights":
        total = self.heidegger + self.spinoza + self.nietzsche
        if total == 0:
            return HSNWeights(1.0, 1.0, 1.0)
        return HSNWeights(
            self.heidegger / total,
            self.spinoza / total,
            self.nietzsche / total,
        )


@dataclass
class LensQuantitativeProfile:
    # You can tune these dimensions as you like.
    groundedness: float      # concreteness / ready-to-hand
    world_integration: float # embeddedness in context
    continuity: float        # smoothness / substance-flow
    unity: float             # degree of non-fragmentation
    intensity: float         # force / energy
    contrast: float          # visual / conceptual contrast

    def as_vector(self) -> list[float]:
        return [
            self.groundedness,
            self.world_integration,
            self.continuity,
            self.unity,
            self.intensity,
            self.contrast,
        ]


class QuantitativeHeidegger:
    def profile(self, concept: str, weight: float) -> LensQuantitativeProfile:
        # Heidegger: high groundedness, world integration; moderate intensity.
        base = LensQuantitativeProfile(
            groundedness=0.9,
            world_integration=0.85,
            continuity=0.5,
            unity=0.6,
            intensity=0.55,
            contrast=0.4,
        )
        return self._scale(base, weight)

    def _scale(self, p: LensQuantitativeProfile, w: float) -> LensQuantitativeProfile:
        return LensQuantitativeProfile(
            groundedness=p.groundedness * w,
            world_integration=p.world_integration * w,
            continuity=p.continuity * w,
            unity=p.unity * w,
            intensity=p.intensity * w,
            contrast=p.contrast * w,
        )


class QuantitativeSpinoza:
    def profile(self, concept: str, weight: float) -> LensQuantitativeProfile:
        # Spinoza: high continuity and unity; moderate groundedness.
        base = LensQuantitativeProfile(
