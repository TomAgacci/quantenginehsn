class QuantitativeNietzsche:
    def profile(self, concept: str, weight: float) -> LensQuantitativeProfile:
        # Nietzsche: high intensity and contrast; lower unity.
        base = LensQuantitativeProfile(
            groundedness=0.5,
            world_integration=0.55,
            continuity=0.45,
            unity=0.4,
            intensity=0.95,
            contrast=0.9,
        )
        return self._scale(base, weight)

    def _scale(self, p: LensQuantitativeProfile, w: float) -> LensQuantitativeProfile:
        return LensQuantitativeProfile(
            groundedness=p.groundedness * w,
            world_integration=p.world_integration * w,
            continuity=p.continuity * w,
            unity=p.unity * w,
            intensity=p.intensity * w,
            contrast=p.contrast * w,
        )


class QuantitativeHSNEngine:
    """
    Quantitative H-S-N Engine

    Usage:
        weights = HSNWeights(heidegger=1.2, spinoza=1.0, nietzsche=1.5)
        engine = QuantitativeHSNEngine(weights)
        out = engine.evaluate("standard hot mug")
        print(out["combined_vector"])
    """

    def __init__(self, weights: HSNWeights | None = None):
        self.weights = (weights or HSNWeights()).normalized()
        self.h_mod = QuantitativeHeidegger()
        self.s_mod = QuantitativeSpinoza()
        self.n_mod = QuantitativeNietzsche()

    def _combine_vectors(
        self,
        h: LensQuantitativeProfile,
        s: LensQuantitativeProfile,
        n: LensQuantitativeProfile,
    ) -> list[float]:
        # Simple sum; you can switch to weighted average or other norms.
        hv = h.as_vector()
        sv = s.as_vector()
        nv = n.as_vector()
        return [
            hv[i] + sv[i] + nv[i]
            for i in range(len(hv))
        ]

    def evaluate(self, concept: str) -> Dict[str, Any]:
        h_profile = self.h_mod.profile(concept, self.weights.heidegger)
        s_profile = self.s_mod.profile(concept, self.weights.spinoza)
        n_profile = self.n_mod.profile(concept, self.weights.nietzsche)

        combined_vector = self._combine_vectors(h_profile, s_profile, n_profile)

        return {
            "concept": concept,
            "weights": asdict(self.weights),
            "profiles": {
                "Heidegger": asdict(h_profile),
                "Spinoza": asdict(s_profile),
                "Nietzsche": asdict(n_profile),
            },
            "combined_vector": combined_vector,
        }


